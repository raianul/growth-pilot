# Dev mode — set to true for local development without external services
# Bypasses auth (auto-creates a pro dev user), external APIs degrade gracefully
DEV_MODE=true

# Supabase (not required when DEV_MODE=true)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# External APIs
SERPAPI_KEY=
FIRECRAWL_API_KEY=
OTTERLY_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Notifications
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=

# App URLs (update for production)
APP_URL=http://localhost:5173
LANDING_URL=http://localhost:5174
API_URL=http://localhost:8000
